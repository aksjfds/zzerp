{
  "name": "frontend",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0 --mode development",
    "dev:prod": "vite --host 0.0.0.0 --mode production",
    "build": "run-p type-check build-only",
    "build:dev": "run-p type-check build-only:dev",
    "build:prod": "run-p type-check build-only:prod",
    "preview": "vite preview",
    "preview:prod": "vite preview --mode production",
    "build-only": "vite build",
    "build-only:dev": "vite build --mode development",
    "build-only:prod": "vite build --mode production",
    "type-check": "vue-tsc --build"
  },
  "dependencies": {
    "axios": "^1.18.0",
    "element-plus": "^2.14.2",
    "pinia": "^3.0.4",
    "vue": "^3.5.32",
    "vue-router": "^5.0.4"
  },
  "devDependencies": {
    "@tsconfig/node24": "^24.0.4",
    "@types/node": "^24.12.2",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/tsconfig": "^0.9.1",
    "npm-run-all2": "^8.0.4",
    "typescript": "~6.0.0",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-vue-components": "^32.1.0",
    "vite": "^8.0.8",
    "vite-plugin-vue-devtools": "^8.1.1",
    "vue-tsc": "^3.2.6"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  }
}
